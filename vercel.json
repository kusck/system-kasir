{
  "version": 2,
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "rewrites": [
    { "source": "/api/health",                    "destination": "/api/health" },
    { "source": "/api/auth",                      "destination": "/api/auth" },
    { "source": "/api/categories",               "destination": "/api/categories" },
    { "source": "/api/products/low-stock",        "destination": "/api/products/low-stock" },
    { "source": "/api/products/barcode/:barcode", "destination": "/api/products/barcode/[barcode]?barcode=:barcode" },
    { "source": "/api/products/:id",              "destination": "/api/products/[id]?id=:id" },
    { "source": "/api/products",                  "destination": "/api/products" },
    { "source": "/api/transactions/checkout",     "destination": "/api/transactions?action=checkout" },
    { "source": "/api/transactions",              "destination": "/api/transactions" },
    { "source": "/api/cash/:action",              "destination": "/api/cash?action=:action" },
    { "source": "/api/cash",                      "destination": "/api/cash" },
    { "source": "/(.*)",                          "destination": "/index.html" }
  ]
}
